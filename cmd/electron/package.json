{
  "name": "grroxy",
  "version": "2026.3.6",
  "author": {
    "name": "Gitesh Sharma",
    "email": "gitesh@grroxy.com"
  },
  "main": "./src/index.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.glitchedgitz.grroxy",
    "productName": "Grroxy",
    "extraResources": [
      {
        "from": "bin/${os}/${arch}/",
        "to": "bin",
        "filter": ["grroxy*", "cook*"]
      }
    ],
    "files": [
      "src/index.js",
      "src/preload.js",
      "src/icons/**/*"
    ],
    "mac": {
      "icon": "src/icons/grroxy.png",
      "target": ["dmg"]
    },
    "win": {
      "icon": "src/icons/grroxy.png",
      "target": ["nsis"]
    },
    "linux": {
      "icon": "src/icons/grroxy.png",
      "target": ["AppImage"]
    }
  }
}
